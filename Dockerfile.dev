# Development Dockerfile - supports both dev server and deployment (Node 22 aligned with engines)
FROM node:22-alpine AS development

# Install basic utilities
RUN apk add --no-cache curl

# Set working directory
WORKDIR /app

# Copy package manifests for dependency installation
COPY package.json pnpm-lock.yaml .npmrc ./

RUN corepack enable && corepack prepare pnpm@11.1.1 --activate
RUN pnpm install --frozen-lockfile

# Copy all source files
COPY . .

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs
RUN adduser -S nextjs -u 1001
RUN chown -R nextjs:nodejs /app
USER nextjs

# Expose port
EXPOSE 80

# For development: use the dev server
# For deployment: build and start production server
CMD if [ "$NODE_ENV" = "production" ]; then \
      echo "Building for production deployment..."; \
      pnpm run build && pnpm start; \
    else \
      echo "Starting development server..."; \
      pnpm run dev; \
    fi
